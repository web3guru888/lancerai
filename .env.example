# LancerAI Environment Variables
# Copy to .env and fill in your Locus credentials

# Locus API (main)
LOCUS_API_KEY=claw_dev_YOUR_KEY_HERE
LOCUS_API_BASE=https://beta-api.paywithlocus.com/api

# BuildWithLocus API (deployment)
BUILD_API_URL=https://beta-api.buildwithlocus.com/v1

# Server config — PORT 8080 required by BuildWithLocus
PORT=8080
HOST=0.0.0.0
AGENT_NAME=LancerAI
AGENT_DESCRIPTION="Autonomous AI freelancer agent"

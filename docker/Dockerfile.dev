# ===================================
# LancerAI — Development Dockerfile
# Hot-reload with tsx watch
# ===================================

FROM node:22-slim

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install

COPY . .

ENV PORT=8080
ENV HOST=0.0.0.0

EXPOSE 8080

CMD ["npx", "tsx", "watch", "src/api/server.ts"]
